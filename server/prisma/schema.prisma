// Malika's Cake Boutique Prisma Schema
// Production datasource: PostgreSQL. Point DATABASE_URL at any hosted
// Postgres (Neon, Supabase, Railway, Render all work) — see DEPLOYMENT.md.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}

model CatalogSize {
  id          String   @id @default(uuid())
  name        String   @unique
  basePrice   Decimal  @map("base_price") @db.Decimal(8, 2)
  servingsMin Int?     @map("servings_min")
  servingsMax Int?     @map("servings_max")
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  orders      Order[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("catalog_sizes")
}

model CatalogFlavor {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  orders      Order[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("catalog_flavors")
}

model CatalogFilling {
  id         String   @id @default(uuid())
  name       String   @unique
  priceAddon Decimal  @map("price_addon") @db.Decimal(8, 2)
  isActive   Boolean  @default(true) @map("is_active")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("catalog_fillings")
}

model CatalogTopper {
  id                  String               @id @default(uuid())
  name                String               @unique
  priceAddon          Decimal              @map("price_addon") @db.Decimal(8, 2)
  imageUrl            String?              @map("image_url")
  isActive            Boolean              @default(true) @map("is_active")
  orderCustomizations OrderCustomization[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@map("catalog_toppers")
}

model Order {
  id          String         @id @default(uuid())
  customerId  String         @map("customer_id")
  customer    Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderNumber String         @unique @map("order_number")
  sizeId      String         @map("size_id")
  size        CatalogSize    @relation(fields: [sizeId], references: [id])
  flavorId    String         @map("flavor_id")
  flavor      CatalogFlavor  @relation(fields: [flavorId], references: [id])
  fillingId   String         @map("filling_id")
  filling     CatalogFilling @relation(fields: [fillingId], references: [id])

  // Pricing
  basePrice          Decimal @map("base_price") @db.Decimal(8, 2)
  customizationTotal Decimal @default(0) @map("customization_total") @db.Decimal(8, 2)
  tax                Decimal @default(0) @db.Decimal(8, 2)
  totalPrice         Decimal @map("total_price") @db.Decimal(8, 2)

  // Dates & Times
  orderDate      DateTime @default(now()) @map("order_date")
  pickupDate     DateTime @map("pickup_date") @db.Date
  pickupTime     DateTime @default(dbgenerated("'12:00:00'::time")) @map("pickup_time") @db.Time
  paymentDueDate DateTime @map("payment_due_date") @db.Date

  // Status: draft | confirmed | paid | in_progress | ready | picked_up | cancelled
  status        String @default("draft")
  // Payment: unpaid | paid | refunded
  paymentStatus String @default("unpaid") @map("payment_status")

  // Special Requests
  allergiesRestrictions String? @map("allergies_restrictions")
  specialRequests       String? @map("special_requests")
  recipientPhone        String? @map("recipient_phone")

  // Delivery (Uber Direct) — deliveryMethod: pickup | delivery
  // deliveryStatus mirrors Uber Direct's lifecycle: pending | courier_assigned
  // | pickup | pickup_complete | dropoff | delivered | canceled
  deliveryMethod    String   @default("pickup") @map("delivery_method")
  deliveryAddress   String?  @map("delivery_address")
  // From Google Places — precise coordinates, so the admin's later "mark
  // ready" re-quote can hand Uber exact lat/lng instead of re-parsing a
  // string (Uber trusts these directly with no independent double-check).
  deliveryLatitude  Decimal? @map("delivery_latitude") @db.Decimal(10, 7)
  deliveryLongitude Decimal? @map("delivery_longitude") @db.Decimal(10, 7)
  deliveryFee       Decimal  @default(0) @map("delivery_fee") @db.Decimal(8, 2)
  deliveryStatus    String?  @map("delivery_status")
  uberDeliveryId    String?  @map("uber_delivery_id")
  uberTrackingUrl   String?  @map("uber_tracking_url")

  customizations OrderCustomization[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([pickupDate])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderCustomization {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  topperId    String        @map("topper_id")
  topper      CatalogTopper @relation(fields: [topperId], references: [id])
  quantity    Int           @default(1)
  priceAtTime Decimal       @map("price_at_time") @db.Decimal(8, 2)
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_customizations")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("viewer")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("admin_users")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  action     String?
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  userId     String?  @map("user_id")
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}
