// Malika's Cake Boutique Prisma Schema
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @unique @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model CatalogSize {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  basePrice   Decimal  @map("base_price") @db.Decimal(8, 2)
  servingsMin Int?     @map("servings_min")
  servingsMax Int?     @map("servings_max")
  description String?
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  orders      Order[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("catalog_sizes")
}

model CatalogFlavor {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique @db.VarChar(100)
  description String?
  imageUrl  String?  @map("image_url") @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  orders    Order[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("catalog_flavors")
}

model CatalogFilling {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique @db.VarChar(100)
  priceAddon Decimal  @map("price_addon") @db.Decimal(8, 2)
  isActive   Boolean  @default(true) @map("is_active")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("catalog_fillings")
}

model CatalogTopper {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                 @unique @db.VarChar(100)
  priceAddon           Decimal                @map("price_addon") @db.Decimal(8, 2)
  imageUrl             String?                @map("image_url") @db.VarChar(500)
  isActive             Boolean                @default(true) @map("is_active")
  orderCustomizations  OrderCustomization[]
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")

  @@map("catalog_toppers")
}

model Order {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId            String                 @map("customer_id") @db.Uuid
  customer              Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderNumber           String                 @unique @db.VarChar(20)
  sizeId                String                 @map("size_id") @db.Uuid
  size                  CatalogSize            @relation(fields: [sizeId], references: [id])
  flavorId              String                 @map("flavor_id") @db.Uuid
  flavor                CatalogFlavor          @relation(fields: [flavorId], references: [id])
  fillingId             String                 @map("filling_id") @db.Uuid
  filling               CatalogFilling         @relation(fields: [fillingId], references: [id])

  // Pricing
  basePrice             Decimal                @map("base_price") @db.Decimal(8, 2)
  customizationTotal    Decimal                @default(0) @map("customization_total") @db.Decimal(8, 2)
  tax                   Decimal                @default(0) @db.Decimal(8, 2)
  totalPrice            Decimal                @map("total_price") @db.Decimal(8, 2)

  // Dates & Times
  orderDate             DateTime               @default(now()) @map("order_date") @db.Date
  pickupDate            DateTime               @map("pickup_date") @db.Date
  pickupTime            DateTime               @default(dbgenerated("'12:00:00'::time")) @map("pickup_time") @db.Time
  paymentDueDate        DateTime               @map("payment_due_date") @db.Date

  // Status
  status                String                 @default("draft") @db.VarChar(50)
  paymentStatus         String                 @default("unpaid") @map("payment_status") @db.VarChar(50)

  // Special Requests
  allergiesRestrictions String?                @map("allergies_restrictions")
  specialRequests       String?                @map("special_requests")
  recipientPhone        String?                @map("recipient_phone") @db.VarChar(20)

  // Relations
  customizations        OrderCustomization[]

  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([pickupDate])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderCustomization {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String        @map("order_id") @db.Uuid
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  topperId    String        @map("topper_id") @db.Uuid
  topper      CatalogTopper @relation(fields: [topperId], references: [id])
  quantity    Int           @default(1)
  priceAtTime Decimal       @map("price_at_time") @db.Decimal(8, 2)
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_customizations")
}

model AdminUser {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.VarChar(255)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  role      String   @default("viewer") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("admin_users")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String? @map("entity_type") @db.VarChar(50)
  entityId  String?  @map("entity_id") @db.Uuid
  action    String?  @map("action") @db.VarChar(50)
  oldValues Json?    @map("old_values")
  newValues Json?    @map("new_values")
  userId    String?  @map("user_id") @db.Uuid
  timestamp DateTime @default(now())

  @@map("audit_logs")
}
