# Database
DATABASE_URL="postgresql://user:password@localhost:5432/malika_cakes"

# Server
NODE_ENV="development"
PORT=3000

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="24h"

# Email (SendGrid or Nodemailer)
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="orders@malikacakes.co.za"
EMAIL_FROM_NAME="Malika's Cake Boutique"

# SMTP (alternative to SendGrid)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Admin Initial Credentials (for seeding)
ADMIN_EMAIL="admin@malikacakes.co.za"
ADMIN_PASSWORD="change-this-password"
