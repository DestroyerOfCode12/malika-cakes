# Database — PostgreSQL (required; SQLite is not supported for this schema).
# Free hosted options that work well for both local dev and production:
# Neon (neon.tech), Supabase, or your Railway/Render project's own Postgres
# add-on. Paste the connection string they give you below.
DATABASE_URL="postgresql://user:password@host:5432/malika_cakes?sslmode=require"

# Server
NODE_ENV="development"
PORT=3000

# Comma-separated list of allowed frontend origins (your Netlify URL, custom
# domain, etc). Defaults to localhost:5173 if unset.
CORS_ORIGIN="http://localhost:5173"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="24h"

# Email (Nodemailer/SMTP). Leave SMTP_HOST empty to log emails to the
# console instead of sending — useful for dev without mail credentials.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="orders@malikacakes.co.za"
EMAIL_FROM_NAME="Malika's Cake Boutique"

# Admin Initial Credentials (for seeding)
ADMIN_EMAIL="admin@malikacakes.co.za"
ADMIN_PASSWORD="change-this-password"
