// Malika's Cake Boutique Prisma Schema
// Dev uses SQLite (zero-install). For production Postgres, switch the
// provider to "postgresql" and restore Decimal types for money fields.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String?  @unique
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}

model CatalogSize {
  id          String   @id @default(uuid())
  name        String   @unique
  basePrice   Float    @map("base_price")
  servingsMin Int?     @map("servings_min")
  servingsMax Int?     @map("servings_max")
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  orders      Order[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("catalog_sizes")
}

model CatalogFlavor {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  orders      Order[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("catalog_flavors")
}

model CatalogFilling {
  id         String   @id @default(uuid())
  name       String   @unique
  priceAddon Float    @map("price_addon")
  isActive   Boolean  @default(true) @map("is_active")
  orders     Order[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("catalog_fillings")
}

model CatalogTopper {
  id                  String               @id @default(uuid())
  name                String               @unique
  priceAddon          Float                @map("price_addon")
  imageUrl            String?              @map("image_url")
  isActive            Boolean              @default(true) @map("is_active")
  orderCustomizations OrderCustomization[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@map("catalog_toppers")
}

model Order {
  id          String        @id @default(uuid())
  customerId  String        @map("customer_id")
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderNumber String        @unique @map("order_number")
  sizeId      String        @map("size_id")
  size        CatalogSize   @relation(fields: [sizeId], references: [id])
  flavorId    String        @map("flavor_id")
  flavor      CatalogFlavor @relation(fields: [flavorId], references: [id])
  fillingId   String        @map("filling_id")
  filling     CatalogFilling @relation(fields: [fillingId], references: [id])

  // Pricing
  basePrice          Float @map("base_price")
  customizationTotal Float @default(0) @map("customization_total")
  tax                Float @default(0)
  totalPrice         Float @map("total_price")

  // Dates & Times (pickupTime stored as "HH:mm" string)
  orderDate      DateTime @default(now()) @map("order_date")
  pickupDate     DateTime @map("pickup_date")
  pickupTime     String   @default("12:00") @map("pickup_time")
  paymentDueDate DateTime @map("payment_due_date")

  // Status: draft | confirmed | paid | in_progress | ready | picked_up | cancelled
  status        String @default("draft")
  // Payment: unpaid | paid | refunded
  paymentStatus String @default("unpaid") @map("payment_status")

  // Special Requests
  allergiesRestrictions String? @map("allergies_restrictions")
  specialRequests       String? @map("special_requests")
  recipientPhone        String? @map("recipient_phone")

  customizations OrderCustomization[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([pickupDate])
  @@index([status])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderCustomization {
  id          String        @id @default(uuid())
  orderId     String        @map("order_id")
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  topperId    String        @map("topper_id")
  topper      CatalogTopper @relation(fields: [topperId], references: [id])
  quantity    Int           @default(1)
  priceAtTime Float         @map("price_at_time")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([orderId])
  @@map("order_customizations")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String    @default("viewer")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("admin_users")
}

model AuditLog {
  id         String   @id @default(uuid())
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  action     String?
  oldValues  String?  @map("old_values")
  newValues  String?  @map("new_values")
  userId     String?  @map("user_id")
  timestamp  DateTime @default(now())

  @@map("audit_logs")
}
